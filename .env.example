# Server-only Google keys. Restrict these by server IP and by API.
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_SOLAR_API_KEY=

# Receives the complete lead JSON payload (optional; best-effort after DB write).
LEAD_WEBHOOK_URL=

# Supabase (service role — server only). When set, POST /api/lead persists
# into public.leads after resolving roofers.slug = payload.rooferId.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of origins allowed to call this API from a browser,
# e.g. https://quoter-widget.vercel.app,https://someroofer.co.uk
# The default "*" allows any origin - fine for development, tighten it in
# production.
QUOTER_ALLOWED_ORIGINS=*
