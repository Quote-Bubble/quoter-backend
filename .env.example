# Server-only Google keys. Restrict these by server IP and by API.
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_SOLAR_API_KEY=

# Receives the complete lead JSON payload (optional; best-effort after DB write).
# Must be https. Optional host allowlist and HMAC secret for X-Quoter-Signature.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_ALLOWED_HOSTS=
LEAD_WEBHOOK_SECRET=

# Resend — emails the roofer when a new lead lands (optional; best-effort after
# the DB write, never fails the request). Recipients are the login emails of the
# roofer's linked members. Without RESEND_API_KEY, lead emails are disabled.
# LEAD_NOTIFY_FROM must use a Resend-verified domain in production; the default
# ("Quoter <onboarding@resend.dev>") only delivers to your own verified address.
# Reply-To defaults to the homeowner's email; set REPLY_TO_LEAD=false to disable.
RESEND_API_KEY=
LEAD_NOTIFY_FROM=
LEAD_NOTIFY_REPLY_TO_LEAD=

# Supabase (service role — server only). When set, POST /api/lead persists
# into public.leads after resolving roofers.slug = payload.rooferId.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — rate limiting + solar/geocode response cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated list of origins allowed to call this API from a browser,
# e.g. https://quoter-widget.vercel.app,https://someroofer.co.uk
# Enumerate Vercel preview origins explicitly — there is no wildcard preview
# regex (that namespace is globally first-come-first-served).
# The default "*" allows any origin - fine for development, tighten it in
# production.
QUOTER_ALLOWED_ORIGINS=*
